<?xml version="1.0"?>
<launch>
  <arg name="world_file" default="$(find robot_description)/worlds/kri_nasional.world"/>
  <arg name="robot_name" default="robot_1"/>
  <arg name="x" default="0.0"/>
  <arg name="y" default="0.0"/>
  <arg name="z" default="0.1"/>
  <arg name="yaw" default="0.0"/>

  <!-- PENTING: Set use_sim_time SEBELUM Gazebo -->
  <param name="use_sim_time" value="true"/>

  <!-- PENTING: Load URDF ke parameter server SEBELUM Gazebo -->
  <param name="robot_description" 
         command="$(find xacro)/xacro '$(find robot_description)/robots/soccer_robot.urdf.xacro' 
                  robot_name:=$(arg robot_name)" />

  <!-- Start Gazebo -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world_file)"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
  </include>

  <!-- Spawn robot in Gazebo (menggunakan URDF dari parameter server) -->
  <node name="spawn_urdf_model" pkg="gazebo_ros" type="spawn_model" 
        output="screen"
        args="-param robot_description -urdf -model $(arg robot_name) 
              -x $(arg x) -y $(arg y) -z $(arg z) -Y $(arg yaw)"
        respawn="false" />

  <!-- Load controller configurations -->
  <rosparam file="$(find soccer_robot_control)/config/soccer_robot_control.yaml" 
            command="load"/>

  <!-- Spawn controllers dengan delay -->
  <node name="controller_spawner" pkg="controller_manager" type="spawner" 
        respawn="false" output="screen"
        launch-prefix="bash -c 'sleep 8; $0 $@'"
        args="joint_state_controller
              first_wheel_velocity_controller
              second_wheel_velocity_controller
              third_wheel_velocity_controller
              forth_wheel_velocity_controller"/>

  <!-- Start Python controller -->
  <node name="soccer_robot_control" pkg="soccer_robot_control" 
        type="soccer_robot_control.py" output="screen" launch-prefix="bash -c 'sleep 10; $0 $@'">
    <param name="robot_name" type="string" value="$(arg robot_name)" />
    <param name="wheel_radius" type="double" value="0.05" />
    <param name="wheel_distance" type="double" value="0.4" />
  </node>

</launch>